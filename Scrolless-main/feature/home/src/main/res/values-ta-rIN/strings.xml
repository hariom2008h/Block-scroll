    <string name="accessibility_explainer_open_source">எங்கள் குறியீடு GitHub இல் 100\% திறந்த மூலமாகும்.</string>
    <string name="accessibility_explainer_privacy_note">குறுகிய வீடியோக்களைக் கண்டறிந்து நிறுத்த மட்டுமே Scrolless இந்த அனுமதியைப் பயன்படுத்துகிறது. நாங்கள் எந்த தனிப்பட்ட தகவலையும் சேகரிப்பதில்லை.</string>
    <string name="accessibility_explainer_proceed_button">அமைப்புகளுக்குச் செல்லவும்</string>
    <string name="accessibility_explainer_step1">Android இன் அணுகல்தன்மை அமைப்புகளைத் திறக்க கீழே உள்ள \"அமைப்புகளுக்குச் செல்லவும்\" என்பதைத் தட்டவும்</string>
    <string name="accessibility_explainer_step2">சேவைகளின் பட்டியலில் பயன்பாடுகளைக் கண்டறிந்து \"Scrolless\" என்பதைத் தட்டவும்</string>
    <string name="accessibility_explainer_step3">முடிவில்லாத ஸ்க்ரோலிங்கை நிறுத்த உங்களுக்கு உதவ Scrolless ஐ இயக்க, சுவிட்சை ON க்கு மாற்றவும்</string>
    <string name="accessibility_explainer_subtitle">குறுகிய வீடியோக்களைக் கண்டறிந்து நிறுத்த Scrolless க்கு அணுகல்தன்மை அணுகல் தேவை.</string>
