<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#95080911"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_dialog_bg"
        android:padding="32dp"
        android:orientation="vertical"
        android:elevation="16dp">

        <!-- Modern, clean typography header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCROLL INTERCEPTED"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:letterSpacing="0.05"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- High-clarity subtitle -->
        <TextView
            android:id="@+id/custom_message_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Instantly gratified dopamine loop detected. Prove you have discipline to continue."
            android:textColor="#B0C4DE"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginTop="12dp"
            android:gravity="center"/>

        <!-- High clarity glassmorphic password input with visibility toggle -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/rounded_edittext_bg">

            <EditText
                android:id="@+id/password_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:paddingStart="20dp"
                android:paddingEnd="52dp"
                android:hint="Enter Master Password"
                android:textColorHint="#82FFFFFF"
                android:textColor="#FFFFFF"
                android:gravity="start|center_vertical"
                android:inputType="textPassword"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/password_toggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                android:layout_marginEnd="6dp"
                android:padding="12dp"
                android:src="@drawable/ic_eye_visible"
                android:tint="#82FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle Password Visibility" />
        </RelativeLayout>

        <!-- High contrast white primary authorize button -->
        <android.widget.Button
            android:id="@+id/unlock_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/rounded_button_bg"
            android:textColor="#12131A"
            android:text="AUTHORIZE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Secondary action: exit to safety, matching dark-red tone of the overlay -->
        <android.widget.Button
            android:id="@+id/exit_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_button_red_bg"
            android:textColor="#FFFFFF"
            android:text="GO BACK / वापस जाएँ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

    </LinearLayout>
</LinearLayout>
