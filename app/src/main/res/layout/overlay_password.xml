<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#95080911"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_dialog_bg"
        android:padding="32dp"
        android:orientation="vertical"
        android:elevation="16dp">

        <!-- Modern, clean typography header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCROLL INTERCEPTED"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:letterSpacing="0.05"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- High-clarity subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Instantly gratified dopamine loop detected. Prove you have discipline to continue."
            android:textColor="#B0C4DE"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginTop="12dp"
            android:gravity="center"/>

        <!-- Glassmorphic text input with centered text and high visibility -->
        <EditText
            android:id="@+id/password_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/rounded_edittext_bg"
            android:padding="16dp"
            android:hint="Enter Master Password"
            android:textColorHint="#82FFFFFF"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:inputType="textPassword"
            android:textSize="16sp" />

        <!-- High contrast white primary authorize button -->
        <Button
            android:id="@+id/unlock_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/rounded_button_bg"
            android:backgroundTint="#FFFFFF"
            android:textColor="#12131A"
            android:text="AUTHORIZE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Secondary action: exit to safety, matching dark-red tone of the overlay -->
        <Button
            android:id="@+id/exit_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_button_bg"
            android:backgroundTint="#CCFF3333"
            android:textColor="#FFFFFF"
            android:text="GO BACK / वापस जाएँ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

    </LinearLayout>
</LinearLayout>
