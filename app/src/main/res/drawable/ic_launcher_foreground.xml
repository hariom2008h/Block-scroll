<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer accent glow for the shield -->
    <path
        android:fillAlpha="0.12"
        android:pathData="M54,18 L82,25 L82,54 C82,74.5 70.8,86.5 54,90 C37.2,86.5 26,74.5 26,54 L26,25 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="54"
                android:endY="90"
                android:startX="54"
                android:startY="18"
                android:type="linear">
                <item android:color="#E2B0DA" android:offset="0.0"/>
                <item android:color="#BAC3FF" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Main Shield Outline with custom line weight -->
    <path
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,24 L78,30 L78,54 C78,71.2 68.8,81.4 54,84 C39.2,81.4 30,71.2 30,54 L30,30 Z">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:endX="54"
                android:endY="84"
                android:startX="54"
                android:startY="24"
                android:type="linear">
                <item android:color="#BAC3FF" android:offset="0.0" />
                <item android:color="#E2B0DA" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Shield Fill (Semi-transparent dark violet glassmorphic look) -->
    <path
        android:fillColor="#331A237E"
        android:pathData="M54,26 L76,31.5 L76,54 C76,69.5 67.5,78.8 54,81.2 C40.5,78.8 32,69.5 32,54 L32,31.5 Z"/>

    <!-- High contrast white pause/lock symbols inside that represent block/detox action -->
    <!-- Left vertical bar of pause -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M43,42 h5 v22 h-5 Z"/>
    <!-- Right vertical bar of pause -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M60,42 h5 v22 h-5 Z"/>

    <!-- Block/Cross overlay representing active screen blocking -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M37,53 L71,53"/>
</vector>
